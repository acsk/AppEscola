/node_modules/

# Expo
.expo/
web-build/
expo-env.d.ts

# dist: commitar para deploy, mas ignorar node_modules da raiz do projeto
# dist/assets/node_modules contém as fontes dos ícones — deve ser commitado
# fonts/: pasta com fontes de ícones (Ionicons, Feather) — deve ser commitada
# dist/fonts/: idem, para produção
# dist/_expo/static/: bundles web (como mobileEscola) — commitar junto com dist/index.html após web:build
deploy-painel-dist.zip

