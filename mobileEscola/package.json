{
  "name": "mobileescola",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "web:build": "expo export --platform web && npm run copy-icons && npm run copy-icons:dist",
    "copy-icons": "node scripts/copy-icons.js",
    "copy-icons:dist": "node scripts/copy-icons.js dist/fonts",
    "build:android": "expo build:android && npm run copy-icons",
    "build:ios": "expo build:ios && npm run copy-icons",
    "postbuild": "npm run copy-icons"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "^2.1.2",
    "@react-navigation/bottom-tabs": "^7.3.10",
    "@react-navigation/native": "^7.1.6",
    "@react-navigation/native-stack": "^7.3.10",
    "axios": "^1.16.0",
    "expo": "~54.0.33",
    "expo-file-system": "^55.0.19",
    "expo-image-manipulator": "^55.0.16",
    "expo-image-picker": "^55.0.20",
    "expo-linking": "~8.0.12",
    "expo-print": "~15.0.8",
    "expo-secure-store": "~15.0.8",
    "expo-sharing": "~14.0.8",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
