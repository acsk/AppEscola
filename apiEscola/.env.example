APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Origens extras para CORS (separadas por vírgula), ex.: http://localhost:8084
# CORS_ALLOWED_ORIGINS=

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

CORA_BASE_URL=https://api.cora.com.br
CORA_API_TOKEN=
CORA_CHARGES_ENDPOINT=/v1/charges
CORA_TIMEOUT=20
CORA_TOKEN_URL_STAGE=https://matls-clients.api.stage.cora.com.br/token
CORA_TOKEN_URL_PROD=https://matls-clients.api.cora.com.br/token
CORA_VERIFY_SSL=true

# Asaas — fallback global se o tenant não tiver credencial em tenant_asaas_credentials
# Preferir cadastro por tenant: POST /api/tenants/{id}/payment-providers/asaas/settings
ASAAS_API_KEY=
ASAAS_BASE_URL=https://api-sandbox.asaas.com/v3
ASAAS_WEBHOOK_TOKEN=
ASAAS_TIMEOUT=25
ASAAS_RETRY_TIMES=3
ASAAS_RETRY_SLEEP_MS=500

VITE_APP_NAME="${APP_NAME}"
